# 复制为 backend/.env 后修改
# 完整方案：PostgreSQL（需 pip install asyncpg）与 Redis
# DATABASE_URL=postgresql+asyncpg://factory:factory@127.0.0.1:5432/factory
# REDIS_URL=redis://127.0.0.1:6379/0

OPENAI_API_KEY=
OPENAI_BASE_URL=
SCRIPT_MODEL=gpt-4o-mini

TTS_PROVIDER=stub

CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# 新闻 RSS：逗号分隔 slug，列表见 GET /api/v1/sources/catalog 或 us_news_sources_catalog.py
# 示例（网络受限环境建议）：
# NEWS_SOURCE_SLUGS=un_news_all,xinhua_world_en,cgtn_world,ap_top,msn_news_us
NEWS_SOURCE_SLUGS=

# 抓取 RSS 的代理（可选）。如你浏览器走了本地代理但后端没走，可在这里填：
# RSS_PROXY_URL=http://127.0.0.1:7890
RSS_PROXY_URL=

# RSS 抓取超时/重试（网络较慢时可适当调大）
RSS_FETCH_TIMEOUT_SECONDS=10
RSS_FETCH_RETRY_COUNT=1

# 任务卡住自动恢复阈值（分钟）：服务启动时会把超过该时长的中间态任务标记为 failed
JOB_STUCK_RECOVER_MINUTES=8
