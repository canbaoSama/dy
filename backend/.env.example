# 复制为 backend/.env 后修改
# 完整方案：PostgreSQL（需 pip install asyncpg）与 Redis
# DATABASE_URL=postgresql+asyncpg://factory:factory@127.0.0.1:5432/factory
# REDIS_URL=redis://127.0.0.1:6379/0

OPENAI_API_KEY=
OPENAI_BASE_URL=
SCRIPT_MODEL=gpt-4o-mini

TTS_PROVIDER=stub

CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# 新闻 RSS：逗号分隔 slug，列表见 GET /api/v1/sources/catalog 或 us_news_sources_catalog.py
# 示例：NEWS_SOURCE_SLUGS=google_news_world,google_news_us,yahoo_news_world,reuters_top,bbc_world
NEWS_SOURCE_SLUGS=

# 抓取 RSS 的代理（可选）。如你浏览器走了本地代理但后端没走，可在这里填：
# RSS_PROXY_URL=http://127.0.0.1:7890
RSS_PROXY_URL=
